def parse_sbox(hex_text):
    vals = [int(x, 16) for x in hex_text.split()]
    assert len(vals) == 256
    return vals


PI = [parse_sbox(PI0_HEX), parse_sbox(PI1_HEX), parse_sbox(PI2_HEX), parse_sbox(PI3_HEX)]


# =====================================================================
# ANF utilities
# =====================================================================

def anf_coefficients_for_bit(sbox, out_bit):
    a = [((sbox[x] >> out_bit) & 1) for x in range(256)]
    for i in range(8):
        step = 1 << i
        for mask in range(256):
            if mask & step:
                a[mask] ^= a[mask ^ step]
    return [mask for mask, coeff in enumerate(a) if coeff]


@lru_cache(None)
def cached_anf(sbox_id, out_bit):
    return tuple(anf_coefficients_for_bit(PI[sbox_id], out_bit))


def monomial_degree(mask):
    return bin(mask).count("1")


def sbox_monomial_occurrences(sbox_id):
    occ = defaultdict(list)
    for out_bit in range(8):
        for mask in cached_anf(sbox_id, out_bit):
            occ[mask].append(out_bit)
    return dict(occ)


def direct_ccx_cost(mask):
    d = monomial_degree(mask)
    if d <= 1:
        return 0
    if d == 2:
        return 1
    return 2 * d - 3


def shared_ccx_cost(mask):
    d = monomial_degree(mask)
    assert d >= 2
    return 2 * d - 2


def should_share_monomial(mask, occurrences):
    d = monomial_degree(mask)
    if d < 2:
        return False
    return shared_ccx_cost(mask) < occurrences * direct_ccx_cost(mask)


# =====================================================================
# State layout for Kalyna-128 state: 8 rows x 2 columns of bytes
# =====================================================================

ROWS = 8
COLS = 2


def byte_index(row, col):
    return 8 * (8 * col + row)


def get_byte(state128, row, col):
    p = byte_index(row, col)
    return state128[p:p + 8]


def set_byte(state128, row, col, byte8):
    p = byte_index(row, col)
    state128[p:p + 8] = byte8


def get_column64(state128, col):
    out = []
    for row in range(ROWS):
        out += get_byte(state128, row, col)
    return out


def set_column64(state128, col, col64):
    for row in range(ROWS):
        set_byte(state128, row, col, col64[8 * row:8 * row + 8])


# =====================================================================
# Optimized S-box implementation
# =====================================================================

def compute_product_to_ancilla(eng, controls):
    d = len(controls)
    assert d >= 2
    temps = eng.allocate_qureg(d - 1)
    Toffoli_gate(eng, controls[0], controls[1], temps[0])
    for i in range(2, d):
        Toffoli_gate(eng, temps[i - 2], controls[i], temps[i - 1])
    return list(temps)


def uncompute_product_from_ancilla(eng, controls, temps):
    d = len(controls)
    assert d >= 2
    for i in reversed(range(2, d)):
        Toffoli_gate(eng, temps[i - 2], controls[i], temps[i - 1])
    Toffoli_gate(eng, controls[0], controls[1], temps[0])


def apply_monomial_xor_direct(eng, controls, target):
    d = len(controls)
    if d == 0:
        X | target
    elif d == 1:
        CNOT | (controls[0], target)
    elif d == 2:
        Toffoli_gate(eng, controls[0], controls[1], target)
    else:
        tmp = eng.allocate_qureg(d - 2)
        Toffoli_gate(eng, controls[0], controls[1], tmp[0])
        for i in range(2, d - 1):
            Toffoli_gate(eng, tmp[i - 2], controls[i], tmp[i - 1])
        Toffoli_gate(eng, tmp[d - 3], controls[d - 1], target)
        for i in reversed(range(2, d - 1)):
            Toffoli_gate(eng, tmp[i - 2], controls[i], tmp[i - 1])
        Toffoli_gate(eng, controls[0], controls[1], tmp[0])
        del tmp


def apply_shared_monomial_xor_clean(eng, controls, targets):
    temps = compute_product_to_ancilla(eng, controls)
    prod = temps[-1]
    for t in targets:
        CNOT | (prod, t)
    uncompute_product_from_ancilla(eng, controls, temps)
    del prod
    del temps


def apply_kalyna_sbox_optimized_to_new_byte(eng, byte8, sbox_id):
    out = eng.allocate_qureg(8)
    occ = sbox_monomial_occurrences(sbox_id)
    for mask in sorted(occ.keys(), key=lambda m: (monomial_degree(m), m)):
        outs = occ[mask]
        d = monomial_degree(mask)
        if d == 0:
            for out_bit in outs:
                X | out[out_bit]
        elif d == 1:
            idx = [i for i in range(8) if (mask >> i) & 1][0]
            for out_bit in outs:
                CNOT | (byte8[idx], out[out_bit])
        else:
            controls = [byte8[i] for i in range(8) if (mask >> i) & 1]
            if should_share_monomial(mask, len(outs)):
                targets = [out[out_bit] for out_bit in outs]
                apply_shared_monomial_xor_clean(eng, controls, targets)
            else:
                for out_bit in outs:
                    apply_monomial_xor_direct(eng, controls, out[out_bit])
    return list(out)


def kalyna_subbytes_128_optimized(eng, state128):
    out = [None] * 128
    for col in range(COLS):
        for row in range(ROWS):
            b = get_byte(state128, row, col)
            sbox_id = row % 4
            b2 = apply_kalyna_sbox_optimized_to_new_byte(eng, b, sbox_id)
            set_byte(out, row, col, b2)
    return out


# =====================================================================
# tau: ShiftRows
# =====================================================================

def kalyna_shiftrows_128_logical(state128):
    out = [None] * 128
    for row in range(ROWS):
        delta = (row * 128) // 512
        for col in range(COLS):
            src_col = (col - delta) % COLS
            b = get_byte(state128, row, src_col)
            set_byte(out, row, col, b)
    return out


# =====================================================================
# psi: MixColumns / MDS layer
# =====================================================================

GF_POLY_LOW = 0x1D
KALYNA_V = [0x01, 0x01, 0x05, 0x01, 0x08, 0x06, 0x07, 0x04]


def gf_mul(a, b):
    res = 0
    aa = a & 0xFF
    bb = b & 0xFF
    for _ in range(8):
        if bb & 1:
            res ^= aa
        carry = aa & 0x80
        aa = (aa << 1) & 0xFF
        if carry:
            aa ^= GF_POLY_LOW
        bb >>= 1
    return res & 0xFF


def byte_to_bits(x):
    return [(x >> i) & 1 for i in range(8)]


def bits_to_byte(bits):
    return sum((bits[i] & 1) << i for i in range(8))


def kalyna_mix_column_bytes(col_bytes):
    out = []
    for i in range(8):
        acc = 0
        for j in range(8):
            coeff = KALYNA_V[(j - i) % 8]
            acc ^= gf_mul(coeff, col_bytes[j])
        out.append(acc)
    return out


def build_mixcol_matrix_64():
    A = np.zeros((64, 64), dtype=np.uint8)
    for i in range(64):
        bits = [0] * 64
        bits[i] = 1
        col_bytes = [bits_to_byte(bits[8 * row:8 * row + 8]) for row in range(8)]
        out_bytes = kalyna_mix_column_bytes(col_bytes)
        out_bits = []
        for b in out_bytes:
            out_bits += byte_to_bits(b)
        for r in range(64):
            A[r, i] = out_bits[r]
    return A


def gauss_jordan_ops_to_I(A):
    A = A.copy().astype(np.uint8)
    n = A.shape[0]
    ops = []
    for p in range(n):
        piv = None
        for r in range(p, n):
            if A[r, p]:
                piv = r
                break
        if piv is None:
            raise ValueError("Matrix is singular. Check MixColumns matrix.")
        if piv != p:
            A[[p, piv]] = A[[piv, p]]
            ops.append(("swap", p, piv))
        for r in range(n):
            if r != p and A[r, p]:
                A[r] ^= A[p]
                ops.append(("rowxor", p, r))
    return ops


_MIXCOL64_OPS = gauss_jordan_ops_to_I(build_mixcol_matrix_64())


def apply_linear_ops_inplace(eng, qubits, ops):
    q = list(qubits)
    for op in reversed(ops):
        if op[0] == "swap":
            i, j = op[1], op[2]
            q[i], q[j] = q[j], q[i]
        else:
            src, dst = op[1], op[2]
            CNOT | (q[src], q[dst])
    return q


def kalyna_mixcolumns_128(eng, state128):
    state = list(state128)
    for col in range(COLS):
        c = get_column64(state, col)
        c2 = apply_linear_ops_inplace(eng, c, _MIXCOL64_OPS)
        set_column64(state, col, c2)
    return state


# =====================================================================
# kappa: XOR round-key addition
# =====================================================================

def kalyna_kappa_xor_key(eng, state128, roundkey128):
    for i in range(128):
        CNOT | (roundkey128[i], state128[i])
    return list(state128)


# =====================================================================
# eta: two modulo 2^64 additions
# =====================================================================

def cuccaro_MAJ(eng, a, b, c):
    CNOT | (a, b)
    CNOT | (a, c)
    Toffoli_gate(eng, b, c, a)


def cuccaro_UMA(eng, a, b, c):
    Toffoli_gate(eng, b, c, a)
    CNOT | (a, c)
    CNOT | (c, b)


def add_mod_2n_inplace(eng, a, b):
    """Compute b <- b + a mod 2^n."""
    n = len(a)
    carry = eng.allocate_qubit()
    cuccaro_MAJ(eng, a[0], b[0], carry)
    for i in range(1, n):
        cuccaro_MAJ(eng, a[i], b[i], a[i - 1])
    CNOT | (a[n - 1], b[n - 1])
    for i in reversed(range(1, n)):
        cuccaro_UMA(eng, a[i], b[i], a[i - 1])
    cuccaro_UMA(eng, a[0], b[0], carry)
    return b


def kalyna_eta_add_round_key_mod64(eng, state128, key128):
    state = list(state128)
    key = list(key128)
    for col in range(COLS):
        s_col = get_column64(state, col)
        k_col = get_column64(key, col)
        add_mod_2n_inplace(eng, k_col, s_col)
        set_column64(state, col, s_col)
    return state


# =====================================================================
# Round functions
# =====================================================================

def kalyna_pi_tau_psi_optimized(eng, state128):
    s = kalyna_subbytes_128_optimized(eng, state128)
    s = kalyna_shiftrows_128_logical(s)
    s = kalyna_mixcolumns_128(eng, s)
    return s


def kalyna_inner_round_128_optimized(eng, state128, roundkey128):
    s = kalyna_subbytes_128_optimized(eng, state128)
    s = kalyna_shiftrows_128_logical(s)
    s = kalyna_mixcolumns_128(eng, s)
    s = kalyna_kappa_xor_key(eng, s, roundkey128)
    return s


def kalyna_final_round_128_optimized(eng, state128, roundkey128):
    s = kalyna_subbytes_128_optimized(eng, state128)
    s = kalyna_shiftrows_128_logical(s)
    s = kalyna_mixcolumns_128(eng, s)
    s = kalyna_eta_add_round_key_mod64(eng, s, roundkey128)
    return s


# =====================================================================
# Kalyna-128/256 key schedule
# =====================================================================

def rotl_logical(qreg, amount):
    q = list(qreg)
    amount %= len(q)
    return q[amount:] + q[:amount]


def rotr_logical(qreg, amount):
    q = list(qreg)
    amount %= len(q)
    if amount == 0:
        return q
    return q[-amount:] + q[:-amount]


def left_bits(qreg, n):
    return list(qreg)[:n]


def right_bits(qreg, n):
    return list(qreg)[-n:]


def select_W_i_128_256(master_key256, even_index):
    """
    Logical input word W_i for even-indexed key generation.
    This is used only when COUNT_INPUT_WORD_COPY=True.
    """
    assert even_index % 2 == 0
    if even_index % 4 == 0:
        # W_i = L_{256,128}(RotR_{16i}(K))
        rotated = rotr_logical(master_key256, 16 * even_index)
        return left_bits(rotated, 128)
    else:
        # W_i = R_{256,128}(RotR_{64 floor(i/4)}(K))
        rotated = rotr_logical(master_key256, 64 * (even_index // 4))
        return right_bits(rotated, 128)


def cnot_copy_word_to_state(eng, word128, state128):
    for i in range(128):
        CNOT | (word128[i], state128[i])
    return state128


def generate_phi_i_explicit(eng, ksigma128):
    """
    Explicit phi_i generation model.
    Constants are not set, because the current paper count includes the eta layer
    but not separate classical-constant X gates. This contributes one eta layer.
    """
    phi = eng.allocate_qureg(128)
    phi = kalyna_eta_add_round_key_mod64(eng, phi, ksigma128)
    return list(phi)


def generate_Ksigma_128_256_optimized(eng, master_key256):
    """
    K_sigma generation for Kalyna-128/256.
    K_alpha = left 128 bits, K_omega = right 128 bits.
    Component structure: 3*pi_opt + 3*tau + 3*psi + 2*eta + kappa.
    """
    print("Building K_sigma generation for Kalyna-128/256...", flush=True)
    K_alpha = left_bits(master_key256, 128)
    K_omega = right_bits(master_key256, 128)

    state = eng.allocate_qureg(128)
    # The nonzero specification constant C_{128,256} only contributes classical Xs.
    # It is omitted here to match the gate-count model used in the draft.

    state = kalyna_eta_add_round_key_mod64(eng, state, K_alpha)
    state = kalyna_pi_tau_psi_optimized(eng, state)

    state = kalyna_kappa_xor_key(eng, state, K_omega)
    state = kalyna_pi_tau_psi_optimized(eng, state)

    state = kalyna_eta_add_round_key_mod64(eng, state, K_alpha)
    state = kalyna_pi_tau_psi_optimized(eng, state)

    return list(state)


def generate_one_even_round_key_128_256_optimized(eng, master_key256, ksigma128, even_index):
    """
    Generate one even-indexed key K_i for i in {0,2,4,...,14}.
    Component structure: 2*eta + 2*pi_opt + 2*tau + 2*psi + kappa,
    plus explicit phi_i generation as one additional eta layer.
    """
    print(f"Building even round key K_{even_index} for Kalyna-128/256...", flush=True)

    phi_i = generate_phi_i_explicit(eng, ksigma128)
    state = eng.allocate_qureg(128)

    if COUNT_INPUT_WORD_COPY:
        Wi = select_W_i_128_256(master_key256, even_index)
        state = cnot_copy_word_to_state(eng, Wi, state)

    # Xi structure: eta(phi_i) -> pi/tau/psi -> kappa(phi_i) -> pi/tau/psi -> eta(phi_i)
    state = kalyna_eta_add_round_key_mod64(eng, state, phi_i)
    state = kalyna_pi_tau_psi_optimized(eng, state)

    state = kalyna_kappa_xor_key(eng, state, phi_i)
    state = kalyna_pi_tau_psi_optimized(eng, state)

    state = kalyna_eta_add_round_key_mod64(eng, state, phi_i)
    return list(state)


def kalyna128_256_key_schedule_optimized_with_phi(eng, master_key256):
    """
    Generate K0,K1,...,K14 for Kalyna-128/256.
    Even keys: K0,K2,K4,K6,K8,K10,K12,K14.
    Odd keys: K_i = RotL_56(K_{i-1}).
    """
    ksigma = generate_Ksigma_128_256_optimized(eng, master_key256)
    roundkeys = [None] * 15

    even_indices = [0, 2, 4, 6, 8, 10, 12, 14]
    for idx in even_indices:
        even_key = generate_one_even_round_key_128_256_optimized(eng, master_key256, ksigma, idx)
        roundkeys[idx] = even_key
        if idx + 1 <= 13:
            print(f"Building odd round key K_{idx + 1} by logical rotation...", flush=True)
            roundkeys[idx + 1] = rotl_logical(even_key, 56)

    return roundkeys


# =====================================================================
# Kalyna-128/256 encryption core
# =====================================================================

def kalyna128_256_encryption_core_optimized(eng, plaintext128, roundkeys):
    """
    Full Kalyna-128/256 encryption core:
      eta(K0), 13 inner rounds with kappa(K1)..kappa(K13), final eta(K14).
    """
    assert len(roundkeys) == 15
    state = kalyna_eta_add_round_key_mod64(eng, plaintext128, roundkeys[0])
    for r in range(1, 14):
        print(f"Building inner round {r}...", flush=True)
        state = kalyna_inner_round_128_optimized(eng, state, roundkeys[r])
    print("Building final round...", flush=True)
    state = kalyna_final_round_128_optimized(eng, state, roundkeys[14])
    return state


