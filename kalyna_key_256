def main():
    parser = argparse.ArgumentParser(description="Depth estimator for optimized Kalyna-128/256.")
    parser.add_argument(
        "--mode",
        choices=["ks", "enc", "full"],
        default="full",
        help="ks = key schedule only, enc = encryption core only, full = key schedule + encryption core",
    )
    parser.add_argument(
        "--count-input-copy",
        action="store_true",
        help="explicitly copy W_i into the even-key working register using 128 CNOTs per even key",
    )
    args, _unknown = parser.parse_known_args()

    global COUNT_INPUT_WORD_COPY
    COUNT_INPUT_WORD_COPY = args.count_input_copy

    if args.mode == "ks":
        run_key_schedule_depth_only()
    elif args.mode == "enc":
        run_encryption_core_depth_only()
    else:
        run_full_depth_with_key_schedule()


if __name__ == "__main__":
    main()
