"""
ProjectQ depth estimator for the optimized full Kalyna-128/256 implementation,
including the key schedule and the encryption core.

This script follows the same component model used in the Kalyna-128/128 draft:
  * optimized shared-monomial ANF S-box layer,
  * ShiftRows as logical wire reindexing,
  * MixColumns synthesized as a CNOT network,
  * eta as two 64-bit Cuccaro-style modulo additions,
  * odd round keys as logical rotations.

By default, the generation of each even round key starts from a fresh 128-qubit
working register, matching the component-count model used in the paper. If you
want to explicitly copy the selected 128-bit word W_i from the 256-bit master key
into the working register, set COUNT_INPUT_WORD_COPY = True. This adds 128 CNOTs
per even-indexed round key and will change the depth/count model.
"""

from __future__ import annotations

import argparse
from functools import lru_cache
from collections import defaultdict

import numpy as np

from projectq import MainEngine
from projectq.ops import X, CNOT, Toffoli
from projectq.cengines import BasicEngine


COUNT_INPUT_WORD_COPY = False
# If True, explicitly CNOT-copy W_i from the 256-bit master key into the
# even-key working register. Leave False to match the paper's current
# component-count estimate.


class DepthEstimator(BasicEngine):
    def __init__(self):
        super().__init__()
        self.depths = {}
        self.max_depth = 0

    def is_available(self, cmd):
        return True

    def receive(self, command_list):
        ignore_gates = {"AllocateQubitGate", "DeallocateQubitGate", "FlushGate"}
        for cmd in command_list:
            gate_name = cmd.gate.__class__.__name__
            if gate_name in ignore_gates:
                continue
            qids = []
            for qureg in cmd.all_qubits:
                for qb in qureg:
                    qids.append(qb.id)
            if not qids:
                continue
            start = max(self.depths.get(qid, 0) for qid in qids)
            new_depth = start + 1
            for qid in qids:
                self.depths[qid] = new_depth
            if new_depth > self.max_depth:
                self.max_depth = new_depth

    def __str__(self):
        return str(self.max_depth)


def Toffoli_gate(eng, a, b, t):
    Toffoli | (a, b, t)


